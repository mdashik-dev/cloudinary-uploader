{
    "name": "cloudinary-uploader-pro",
    "version": "1.0.4",
    "description": "A feature-rich Cloudinary uploader with validation, transforms, bulk ops, and more",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src --ext .ts"
    },
    "keywords": [
        "cloudinary",
        "upload",
        "image",
        "video",
        "file",
        "uploader"
    ],
    "author": "Md Ashik",
    "license": "MIT",
    "dependencies": {
        "cloudinary": "^2.0.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "tsup": "^8.0.0",
        "tsx": "^4.21.0",
        "typescript": "^5.0.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
